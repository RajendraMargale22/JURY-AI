# API Base URL (Railway main backend URL in production)
REACT_APP_API_URL=http://localhost:5000/api

# Chatbot Backend URL (Railway chatbot service URL in production)
REACT_APP_CHATBOT_API_URL=http://localhost:8000

# Contract Review Backend URL (Railway contract-review service URL in production)
REACT_APP_CONTRACT_REVIEW_API_URL=http://localhost:8001

# Contract Review API Key
REACT_APP_CONTRACT_REVIEW_API_KEY=dev-local-key

# Firebase Web App Config (Google Auth)
REACT_APP_FIREBASE_API_KEY=your-firebase-web-api-key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_APP_ID=your-firebase-app-id
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id

# News API (optional)
REACT_APP_NEWS_API_KEY=your-newsapi-key
